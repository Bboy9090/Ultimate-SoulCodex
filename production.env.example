# ── SOUL CODEX PRODUCTION ENVIRONMENT ──────────────────────────────────────────

# Server Configuration
NODE_ENV=production
PORT=3000
SESSION_SECRET=your_long_random_session_secret_here

# Domain Configuration
# The base URL for your hosted backend (e.g., https://api.soulcodex.app)
APP_URL=https://your-domain.com

# Database Configuration (PostgreSQL / Neon)
DATABASE_URL=postgresql://user:password@hostname:port/dbname?sslmode=require

# AI Configuration (REQUIRED)
GEMINI_API_KEY=your_gemini_api_key
OPENAI_API_KEY=your_openai_api_key

# Payment Configuration (Optional)
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# Security
# Set this to true to enable secure cookies (requires HTTPS)
SECURE_COOKIES=true

# Capacitor / Mobile
# The URL where your backend is hosted (used by the mobile app)
CAPACITOR_SERVER_URL=https://your-domain.com
