+// Vimshottari Dasha System - 120 year cycle
+const DASHA_PERIODS = [
+  { planet: "Ketu", years: 7 },
+  { planet: "Venus", years: 20 },
+  { planet: "Sun", years: 6 },
+  { planet: "Moon", years: 10 },
+  { planet: "Mars", years: 7 },
