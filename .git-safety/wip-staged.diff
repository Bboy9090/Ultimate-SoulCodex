+  if (humanDesignType === 'Manifestor') archetypeKey = 'visionary-revolutionary';
+  if (humanDesignType === 'Projector') archetypeKey = 'mystic-healer';
+  if (humanDesignType === 'Reflector') archetypeKey = 'mystic-healer';
