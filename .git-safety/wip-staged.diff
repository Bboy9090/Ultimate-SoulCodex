+    },
+    layer2: data.deep,
+    layer3: [
+      { label: "Type", value: hdType },
+      ...(strategy ? [{ label: "Strategy", value: strategy }] : []),
+      ...(authority ? [{ label: "Authority", value: authority }] : []),
+    ],
+  }
