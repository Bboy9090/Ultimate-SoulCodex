+  box-shadow: 0 8px 32px rgba(242,201,76,0.1), 0 0 0 1px rgba(242,201,76,0.08);
+}
+
+/* ─── Upgrade CTA button ─── */
+.btn-upgrade {
+  display: inline-flex;
+  align-items: center;
+  justify-content: center;
+  gap: 6px;
+  padding: 0.65rem 1.4rem;
