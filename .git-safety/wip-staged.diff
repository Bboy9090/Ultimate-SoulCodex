+  topThemes: string[];
+  coreNature: string;
+  stressPattern: string;
+  decisionStyle: string;
+  relationshipStyle: string;
+  blindSpot: string;
+  growthEdge: string;
+  currentPhaseMeaning: string;
+  practicalGuidance: string[];
