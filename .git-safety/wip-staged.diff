+}
+.animate-messageIn { animation: messageIn 0.3s var(--ease-out-expo); }
+
+/* ═══════════════════════════════════════════════════════════════════════════
+   SOUL CODEX — PREMIUM & MONETIZATION STYLES
+   ═══════════════════════════════════════════════════════════════════════════ */
+
+/* ─── Gold shimmer animation ─── */
+@keyframes goldShimmer {
+  0%   { background-position: -200% center; }
