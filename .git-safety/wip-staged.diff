+  astrologyData: any,
+  numerologyData: any,
+  personalityData: any
+): string {
+  // Create comprehensive hash from ALL profile data
+  const profileSignature = JSON.stringify({
+    sun: astrologyData?.sunSign,
+    moon: astrologyData?.moonSign,
+    rising: astrologyData?.risingSign,
+    lifePath: numerologyData?.lifePath,
