+import type { TimelinePhase } from "./types";
+
+export interface PhaseDefinition {
+  name: TimelinePhase;
+  summary: string;
+  focus: string;
+  do: string[];
+  dont: string[];
+  next: TimelinePhase;
+}
+
+export const PHASES: Record<TimelinePhase, PhaseDefinition> = {
+  Ignition: {
+    name: "Ignition",
+    summary:
+      "A raw-start period where identity, direction, and energy are being lit from scratch. You are building momentum before you have proof it will work.",
+    focus:
+      "Launch the things you have been delaying. Establish a physical routine and clear a single primary direction.",
+    do: [
+      "Start the project or relationship with no expectation of immediate return",
+      "Set a 12-month target you can track weekly",
+      "Build small daily habits that compound over the year",
+      "Say yes to unfamiliar situations that stretch your current frame",
+    ],
+    dont: [
+      "Demand immediate results — the payoff is downstream",
+      "Overcommit to too many directions at once",
+      "Rely on external validation before you have built anything",
+      "Ignore the signals from your body — energy is your main resource right now",
+    ],
+    next: "Exposure",
+  },
+  Exposure: {
+    name: "Exposure",
+    summary:
+      "What you built is now visible to others. Feedback — wanted and unwanted — arrives. You are learning what the world reflects back.",
+    focus:
