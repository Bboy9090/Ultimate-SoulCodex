+      sun: degreeToGateAndLine(unconsciousSunLongitude),
+      earth: getEarthGateAndLine(unconsciousSunLongitude),
+      moon: toGateAndLine(unconsciousAstroData.planets.moon.sign, unconsciousAstroData.planets.moon.degree),
