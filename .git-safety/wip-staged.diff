+}
+
+@layer components {
+  .cosmic-gradient {
+    background: linear-gradient(135deg, hsl(240, 10%, 3.9%) 0%, hsl(267, 30%, 15%) 50%, hsl(240, 10%, 3.9%) 100%);
+  }
+
+  .mystical-glow {
+    box-shadow: 0 0 30px hsla(267, 84%, 64%, 0.3);
+  }
+
+  .glassmorphism {
+    background: hsla(240, 4%, 16%, 0.8);
+    backdrop-filter: blur(10px);
+    border: 1px solid hsla(240, 4%, 25%, 0.3);
+  }
+
+  .feature-card {
+    transition: all 0.3s ease;
+  }
+
+  .feature-card:hover {
+    transform: translateY(-5px);
+  }
+
+  .cosmic-border {
+    background: linear-gradient(45deg, hsl(267, 84%, 64%), hsl(45, 96%, 68%), hsl(267, 84%, 64%));
+    padding: 1px;
+    border-radius: 0.75rem;
+  }
+
+  .cosmic-border-inner {
+    background: hsl(240, 10%, 3.9%);
+    border-radius: calc(0.75rem - 1px);
+  }
+
+  .scroll-down {
+    transform: translateY(-100%);
+  }
+
+  .scroll-up {
+    transform: translateY(0);
+  }
+}
+/* ─── CSS Custom Properties ─── */
+:root {
+  /* Core palette */
+  --void:              #0B0E23;
+  --deep:              #0e1128;
+  --surface:           #141028;
+  --card-bg:           rgba(28, 22, 53, 0.72);
+  --card-border:       rgba(123, 97, 255, 0.13);
+
+  /* Cosmic accents */
+  --cosmic-purple:     #7c3aed;
+  --cosmic-violet:     #8b5cf6;
+  --cosmic-lavender:   #a78bfa;
+  --cosmic-pink:       #ec4899;
+  --cosmic-rose:       #f472b6;
+  --cosmic-cyan:       #22d3ee;
+  --cosmic-teal:       #2dd4bf;
+  --cosmic-gold:       #F2C94C;
+  --cosmic-amber:      #f59e0b;
+  --codex-purple:      #7B61FF;
+  --codex-purple-soft: #9B8AFF;
+  --codex-gold:        #F2C94C;
+  --codex-blue:        #6BA7FF;
+
+  /* Glass & shadow */
+  --glass-bg:          rgba(28, 22, 53, 0.68);
+  --glass-border:      rgba(123, 97, 255, 0.14);
+  --shadow-glow:       0 0 32px rgba(123, 97, 255, 0.2);
+  --shadow-glow-gold:  0 0 32px rgba(242, 201, 76, 0.14);
+  --shadow-card:       0 8px 40px rgba(0, 0, 0, 0.5);
+  --shadow-elevated:   0 16px 48px rgba(0, 0, 0, 0.55), 0 0 0 1px rgba(255,255,255,0.03);
+
+  /* Typography */
+  --font-display:      'Space Grotesk', 'Inter', sans-serif;
+  --font-oracle:       'Crimson Pro', Georgia, 'Times New Roman', serif;
+  --font-sans:         'Inter', sans-serif;
+
+  /* Easing */
+  --ease-out-expo:     cubic-bezier(0.16, 1, 0.3, 1);
+  --ease-bounce:       cubic-bezier(0.34, 1.56, 0.64, 1);
+  --transition-fast:   150ms cubic-bezier(0.4, 0, 0.2, 1);
+  --transition-base:   250ms cubic-bezier(0.4, 0, 0.2, 1);
+  --transition-slow:   400ms cubic-bezier(0.4, 0, 0.2, 1);
+  --transition-bounce: 500ms cubic-bezier(0.34, 1.56, 0.64, 1);
+}
+
+* {
+  box-sizing: border-box;
+  margin: 0;
+  padding: 0;
+}
+
+html {
+  font-size: 16px;
+  scroll-behavior: smooth;
+  -webkit-font-smoothing: antialiased;
+  -moz-osx-font-smoothing: grayscale;
+  text-rendering: optimizeLegibility;
+}
+
+body {
+  background: var(--void);
+  color: #EAEAF5;
+  font-family: var(--font-sans);
+  min-height: 100dvh;
+  padding-bottom: 5rem;
+  line-height: 1.65;
+  overflow-x: hidden;
+  /* Layered cosmic background */
+  background-image:
+    radial-gradient(ellipse 80% 50% at 20% 40%, rgba(123,97,255,0.09) 0%, transparent 60%),
+    radial-gradient(ellipse 60% 40% at 80% 20%, rgba(242,201,76,0.06) 0%, transparent 55%),
+    radial-gradient(ellipse 70% 60% at 50% 90%, rgba(107,167,255,0.05) 0%, transparent 60%),
+    radial-gradient(ellipse 100% 80% at 50% 50%, rgba(26,19,56,0.7) 0%, transparent 70%);
+  background-attachment: fixed;
+}
+
+/* ─── Starfield overlay ─── */
+body::before {
+  content: '';
+  position: fixed;
+  inset: 0;
+  background-image:
+    radial-gradient(1px 1px at 15% 12%, rgba(255,255,255,0.22), transparent),
+    radial-gradient(1.5px 1.5px at 28% 35%, rgba(255,255,255,0.16), transparent),
+    radial-gradient(1px 1px at 42% 8%, rgba(255,255,255,0.20), transparent),
+    radial-gradient(1.5px 1.5px at 55% 55%, rgba(255,255,255,0.14), transparent),
+    radial-gradient(1px 1px at 68% 22%, rgba(255,255,255,0.18), transparent),
+    radial-gradient(1px 1px at 78% 75%, rgba(255,255,255,0.12), transparent),
+    radial-gradient(1.5px 1.5px at 88% 40%, rgba(255,255,255,0.20), transparent),
+    radial-gradient(1px 1px at 95% 15%, rgba(255,255,255,0.16), transparent),
+    radial-gradient(1px 1px at 8% 65%, rgba(255,255,255,0.14), transparent),
+    radial-gradient(1.5px 1.5px at 35% 88%, rgba(255,255,255,0.18), transparent),
+    radial-gradient(1px 1px at 62% 92%, rgba(255,255,255,0.12), transparent),
+    radial-gradient(1px 1px at 72% 5%, rgba(255,255,255,0.16), transparent);
+  background-size: 100% 100%;
+  animation: twinkle 12s ease-in-out infinite;
+  pointer-events: none;
+  z-index: 0;
+  opacity: 0.55;
+}
+
+/* ─── Subtle nebula depth ─── */
+body::after {
+  content: '';
+  position: fixed;
+  inset: 0;
+  background:
+    radial-gradient(ellipse 40% 30% at 10% 80%, rgba(123,97,255,0.04) 0%, transparent 70%),
+    radial-gradient(ellipse 35% 25% at 90% 10%, rgba(242,201,76,0.03) 0%, transparent 70%);
+  pointer-events: none;
+  z-index: 0;
+}
+
+@keyframes twinkle {
+  0%, 100% { opacity: 0.55; transform: scale(1); }
+  33%       { opacity: 0.75; transform: scale(1.002); }
+  66%       { opacity: 0.45; transform: scale(0.999); }
+}
+
+#__next, #root { position: relative; z-index: 1; }
+
+/* ─── Gradient text utilities ─── */
+.gradient-text {
+  background: linear-gradient(135deg, #9B8AFF 0%, #ec4899 45%, #22d3ee 100%);
+  -webkit-background-clip: text;
+  -webkit-text-fill-color: transparent;
+  background-clip: text;
+}
+
+.gradient-text-gold {
+  background: linear-gradient(135deg, #F2C94C 0%, #fbbf24 50%, #F2C94C 100%);
+  -webkit-background-clip: text;
+  -webkit-text-fill-color: transparent;
+  background-clip: text;
+}
+
+.text-gold-gradient {
+  background: linear-gradient(135deg, #F2C94C 0%, #E6C27A 60%, #F2C94C 100%);
+  -webkit-background-clip: text;
+  -webkit-text-fill-color: transparent;
+  background-clip: text;
+}
+
+.text-purple-gradient {
+  background: linear-gradient(135deg, #7B61FF 0%, #9B8AFF 100%);
+  -webkit-background-clip: text;
+  -webkit-text-fill-color: transparent;
+  background-clip: text;
+}
+
+/* ─── Buttons ─── */
+.btn-primary {
+  display: inline-flex;
+  align-items: center;
+  justify-content: center;
+  padding: 0.75rem 1.5rem;
+  background: linear-gradient(135deg, #7B61FF 0%, #9B8AFF 100%);
+  color: #fff;
+  font-size: 0.875rem;
+  font-weight: 600;
+  letter-spacing: 0.03em;
+  border: none;
+  border-radius: 16px;
+  cursor: pointer;
+  transition: opacity var(--transition-fast), box-shadow var(--transition-fast), transform var(--transition-fast);
+  box-shadow: 0 4px 18px rgba(123, 97, 255, 0.32), inset 0 1px 0 rgba(255,255,255,0.12);
+  text-decoration: none;
+  min-height: 44px;
+  position: relative;
+  overflow: hidden;
+}
+
+.btn-primary::after {
+  content: '';
+  position: absolute;
+  inset: 0;
+  background: linear-gradient(135deg, rgba(255,255,255,0.08) 0%, transparent 60%);
+  border-radius: inherit;
+  pointer-events: none;
+}
+
+.btn-primary:hover {
+  opacity: 0.93;
+  box-shadow: 0 6px 28px rgba(123, 97, 255, 0.48), inset 0 1px 0 rgba(255,255,255,0.14);
+  transform: translateY(-1px);
+}
+
+.btn-primary:active {
+  transform: translateY(0);
+  opacity: 0.88;
+}
+
+.btn-ghost {
+  display: inline-flex;
+  align-items: center;
+  justify-content: center;
+  padding: 0.5rem 1rem;
+  background: transparent;
+  color: #8B87A8;
+  font-size: 0.875rem;
+  font-weight: 500;
+  border: 1px solid rgba(45, 37, 84, 0.65);
+  border-radius: 16px;
+  cursor: pointer;
+  transition: color var(--transition-fast), border-color var(--transition-fast), background var(--transition-fast);
+  text-decoration: none;
+  min-height: 44px;
+}
+
+.btn-ghost:hover {
+  color: #EAEAF5;
+  border-color: rgba(123, 97, 255, 0.42);
+  background: rgba(123, 97, 255, 0.07);
+}
+
+/* ─── Onboarding Option Cards ─── */
+.option-card {
+  display: block;
+  width: 100%;
+  text-align: left;
+  padding: 1rem 1.25rem;
+  background: rgba(28, 22, 53, 0.68);
+  border: 1px solid rgba(123, 97, 255, 0.14);
+  border-radius: 16px;
+  cursor: pointer;
+  transition: all 0.25s var(--ease-out-expo);
+  color: #EAEAF5;
+  font-family: inherit;
+  backdrop-filter: blur(8px);
+  -webkit-backdrop-filter: blur(8px);
+}
+
+.option-card:hover {
+  border-color: rgba(123, 97, 255, 0.35);
+  background: rgba(123, 97, 255, 0.07);
+  transform: translateY(-1px);
+  box-shadow: 0 4px 20px rgba(0,0,0,0.3);
+}
+
+.option-card.selected {
+  background: rgba(123, 97, 255, 0.14);
+  border-color: #7B61FF;
+  box-shadow: 0 0 22px rgba(123, 97, 255, 0.22), inset 0 1px 0 rgba(255,255,255,0.05);
+  transform: none;
+}
+
+/* ─── Chip Buttons ─── */
+.chip-btn {
+  padding: 0.6rem 1rem;
+  background: rgba(28, 22, 53, 0.68);
+  border: 1px solid rgba(123, 97, 255, 0.14);
+  border-radius: 9999px;
+  cursor: pointer;
+  color: #8B87A8;
+  font-weight: 400;
+  font-size: 0.875rem;
+  transition: all 0.22s var(--ease-out-expo);
+  min-height: 44px;
+  font-family: inherit;
+}
+
+.chip-btn:hover {
+  border-color: rgba(123, 97, 255, 0.35);
+  color: #EAEAF5;
+  background: rgba(123, 97, 255, 0.06);
+}
+
+.chip-btn.selected {
+  background: rgba(123, 97, 255, 0.18);
+  border-color: #7B61FF;
+  color: #EAEAF5;
+  font-weight: 600;
+  box-shadow: 0 0 14px rgba(123, 97, 255, 0.22);
+}
+
+/* ─── Confidence Badge ─── */
+.confidence-badge {
+  display: inline-flex;
+  align-items: center;
+  gap: 0.35rem;
+  border-radius: 9999px;
+  padding: 0.22rem 0.7rem;
+  font-size: 0.68rem;
+  font-weight: 600;
+  letter-spacing: 0.07em;
+  text-transform: uppercase;
+  cursor: help;
+  user-select: none;
+}
+.confidence-badge.verified   { color: #22c55e; background: rgba(34,197,94,0.12);   border: 1px solid rgba(34,197,94,0.35); }
+.confidence-badge.partial    { color: #f59e0b; background: rgba(245,158,11,0.12);  border: 1px solid rgba(245,158,11,0.35); }
+.confidence-badge.unverified { color: #6b7280; background: rgba(107,114,128,0.12); border: 1px solid rgba(107,114,128,0.35); }
+
+/* ─── Progress Bar ─── */
+.progress-bar {
+  height: 3px;
+  background: rgba(45,37,84,0.55);
+  border-radius: 2px;
+  overflow: hidden;
+}
+.progress-bar-fill {
+  height: 100%;
+  background: linear-gradient(90deg, #7B61FF, #9B8AFF, #F2C94C);
+  background-size: 200% 100%;
+  border-radius: 2px;
+  transition: width 0.45s var(--ease-out-expo);
+  animation: gradientShift 3s ease infinite;
+}
+
+/* ─── Tags ─── */
+.tag {
+  display: inline-flex;
+  align-items: center;
+  padding: 0.25rem 0.75rem;
+  background: rgba(28,22,53,0.8);
+  border: 1px solid rgba(45,37,84,0.65);
+  border-radius: 9999px;
+  font-size: 0.75rem;
+  color: #8B87A8;
+  font-weight: 500;
+}
+.tag-purple { border-color: rgba(123,97,255,0.35); color: #9B8AFF; background: rgba(123,97,255,0.09); }
+.tag-gold   { border-color: rgba(242,201,76,0.35);  color: #F2C94C; background: rgba(242,201,76,0.07); }
+.tag-blue   { border-color: rgba(107,167,255,0.35); color: #6BA7FF; background: rgba(107,167,255,0.07); }
+
+/* ─── Stagger animation ─── */
+.stagger > * { animation: stagger 0.45s var(--ease-out-expo) both; }
+.stagger > *:nth-child(1) { animation-delay: 0ms; }
+.stagger > *:nth-child(2) { animation-delay: 75ms; }
+.stagger > *:nth-child(3) { animation-delay: 150ms; }
+.stagger > *:nth-child(4) { animation-delay: 225ms; }
+.stagger > *:nth-child(5) { animation-delay: 300ms; }
+.stagger > *:nth-child(6) { animation-delay: 375ms; }
+@keyframes stagger {
+  from { opacity: 0; transform: translateY(18px); }
+  to   { opacity: 1; transform: translateY(0); }
+}
+
+/* ─── Glassmorphism card ─── */
+.card {
+  background: var(--card-bg);
+  backdrop-filter: blur(18px);
+  -webkit-backdrop-filter: blur(18px);
+  border-radius: 20px;
+  padding: 22px 24px;
+  border: 1px solid var(--card-border);
+  box-shadow:
+    0 8px 36px rgba(0, 0, 0, 0.42),
+    inset 0 1px 0 rgba(255, 255, 255, 0.045),
+    inset 0 -1px 0 rgba(0, 0, 0, 0.12);
+  transition:
+    border-color var(--transition-base),
+    box-shadow var(--transition-base),
+    transform 0.2s ease;
+  position: relative;
+  overflow: hidden;
+}
+
+/* Subtle inner highlight */
+.card::before {
+  content: '';
+  position: absolute;
+  top: 0;
+  left: 0;
+  right: 0;
+  height: 1px;
+  background: linear-gradient(90deg, transparent 0%, rgba(255,255,255,0.06) 50%, transparent 100%);
+  pointer-events: none;
+}
+
+.card:hover {
+  border-color: rgba(123, 97, 255, 0.26);
+  box-shadow:
+    0 10px 40px rgba(0, 0, 0, 0.45),
+    0 0 28px rgba(123, 97, 255, 0.1),
+    inset 0 1px 0 rgba(255, 255, 255, 0.06),
+    inset 0 -1px 0 rgba(0, 0, 0, 0.12);
+  transform: translateY(-1px);
+}
+
+/* Gold variant */
+.card-gold {
+  border-color: rgba(242, 201, 76, 0.18);
+  box-shadow:
+    0 8px 36px rgba(0,0,0,0.42),
+    0 0 24px rgba(242,201,76,0.07),
+    inset 0 1px 0 rgba(255,255,255,0.045);
+}
+.card-gold:hover {
+  border-color: rgba(242, 201, 76, 0.35);
+  box-shadow:
+    0 10px 40px rgba(0,0,0,0.45),
+    0 0 32px rgba(242,201,76,0.12),
+    inset 0 1px 0 rgba(255,255,255,0.06);
+}
+
+/* Blue variant */
+.card-blue {
+  border-color: rgba(107, 167, 255, 0.18);
+  box-shadow:
+    0 8px 36px rgba(0,0,0,0.42),
+    0 0 24px rgba(107,167,255,0.07),
+    inset 0 1px 0 rgba(255,255,255,0.045);
+}
+
+/* ─── Typography ─── */
+.card-title {
+  font-size: 13px;
+  font-weight: 700;
+  margin-bottom: 14px;
+  text-align: center;
+  letter-spacing: 0.1em;
+  text-transform: uppercase;
+  color: #EAEAF5;
+}
+
+.card-subtitle {
+  color: #8B87A8;
+  font-size: 14px;
+  line-height: 1.72;
+}
+
+/* Display headings — serif, gold */
+.heading-display {
+  font-family: var(--font-oracle);
+  color: #F2C94C;
+  letter-spacing: -0.01em;
+  line-height: 1.3;
+}
+
+/* Space Grotesk display headings */
+.heading-display-sans {
+  font-family: var(--font-display);
+  font-weight: 700;
+  letter-spacing: -0.025em;
+  color: #EAEAF5;
+  line-height: 1.2;
+}
+
+/* Oracle text — centered, constrained, elevated */
+.oracle-text {
+  font-family: var(--font-oracle);
+  text-align: center;
+  max-width: 400px;
+  margin: 0 auto;
+  line-height: 1.8;
+  color: #EAEAF5;
+  font-size: 1rem;
+  font-style: italic;
+}
+
+/* Section labels */
+.section-label {
+  font-size: 10px;
+  font-weight: 700;
+  letter-spacing: 0.14em;
+  text-transform: uppercase;
+  color: #8B87A8;
+  font-family: var(--font-display);
+}
+
+/* ─── Keyframe animations ─── */
+@keyframes fadeIn {
+  from { opacity: 0; transform: translateY(14px); }
+  to   { opacity: 1; transform: translateY(0); }
+}
+
+@keyframes fadeInScale {
+  from { opacity: 0; transform: scale(0.96); }
+  to   { opacity: 1; transform: scale(1); }
+}
+
+@keyframes slideUp {
+  from { opacity: 0; transform: translateY(22px); }
+  to   { opacity: 1; transform: translateY(0); }
+}
+
+@keyframes slideDown {
+  from { opacity: 0; transform: translateY(-12px); }
+  to   { opacity: 1; transform: translateY(0); }
+}
+
+@keyframes gradientShift {
+  0%   { background-position: 0% 50%; }
+  50%  { background-position: 100% 50%; }
+  100% { background-position: 0% 50%; }
+}
+
+@keyframes pulseGlow {
+  0%, 100% {
+    box-shadow:
+      0 8px 36px rgba(0,0,0,0.42),
+      inset 0 1px 0 rgba(255,255,255,0.045);
+  }
+  50% {
+    box-shadow:
+      0 8px 36px rgba(0,0,0,0.42),
+      0 0 24px rgba(123,97,255,0.2),
+      inset 0 1px 0 rgba(255,255,255,0.06);
+  }
+}
+
+@keyframes pulseGlowGold {
+  0%, 100% {
+    box-shadow: 0 8px 36px rgba(0,0,0,0.42), inset 0 1px 0 rgba(255,255,255,0.045);
+  }
+  50% {
+    box-shadow: 0 8px 36px rgba(0,0,0,0.42), 0 0 24px rgba(242,201,76,0.18), inset 0 1px 0 rgba(255,255,255,0.06);
+  }
+}
+
+@keyframes floatUp {
+  0%, 100% { transform: translateY(0); }
+  50%       { transform: translateY(-4px); }
+}
+
+@keyframes shimmer {
+  0%   { background-position: -200% 0; }
+  100% { background-position: 200% 0; }
+}
+
+@keyframes spin {
+  from { transform: rotate(0deg); }
+  to   { transform: rotate(360deg); }
+}
+
+@keyframes breathe {
+  0%, 100% { opacity: 0.7; transform: scale(1); }
+  50%       { opacity: 1; transform: scale(1.015); }
+}
+
+/* ─── Animation utility classes ─── */
+.animate-fadeIn        { animation: fadeIn 0.45s var(--ease-out-expo); }
+.animate-slideUp       { animation: slideUp 0.5s var(--ease-out-expo); }
+.animate-slideDown     { animation: slideDown 0.35s var(--ease-out-expo); }
+.animate-fadeInScale   { animation: fadeInScale 0.35s var(--ease-out-expo); }
+.animate-pulseGlow     { animation: pulseGlow 4s ease-in-out infinite; }
+.animate-pulseGlowGold { animation: pulseGlowGold 4s ease-in-out infinite; }
+.animate-floatUp       { animation: floatUp 6s ease-in-out infinite; }
+.animate-breathe       { animation: breathe 5s ease-in-out infinite; }
+.animate-spin          { animation: spin 1s linear infinite; }
+
+/* ─── Shimmer skeleton ─── */
+.skeleton {
+  background: linear-gradient(90deg, rgba(45,37,84,0.8) 25%, rgba(58,48,104,0.9) 50%, rgba(45,37,84,0.8) 75%);
+  background-size: 200% 100%;
+  animation: shimmer 1.6s infinite;
+  border-radius: 8px;
+}
+
+/* ─── Focus states ─── */
+input:focus, textarea:focus, button:focus-visible {
+  outline: 2px solid rgba(123, 97, 255, 0.55);
+  outline-offset: 2px;
+}
+
+/* ─── Custom inputs ─── */
+input, textarea, select {
+  background: rgba(20, 16, 40, 0.65);
+  border: 1px solid rgba(45, 37, 84, 0.85);
+  color: #EAEAF5;
+  transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
+  border-radius: 10px;
+  padding: 0.68rem 0.95rem;
+  font-family: inherit;
+  font-size: 0.9rem;
+  width: 100%;
+}
+
+input:focus, textarea:focus, select:focus {
+  border-color: rgba(123, 97, 255, 0.5);
+  box-shadow: 0 0 0 3px rgba(123, 97, 255, 0.1);
+  outline: none;
+}
+
+input::placeholder, textarea::placeholder {
+  color: rgba(139, 135, 168, 0.65);
+}
+
+/* ─── Scrollbar ─── */
