+function biographyFallback(profile: any): FallbackResult {
+  const d = extractCoreData(profile);
+
+  const lines: string[] = [];
+  lines.push(
+    `I am a ${d.archetype}${d.sunSign ? `. My ${d.sunSign} Sun drives me to act fast — I pick up on tension before anyone names it` : ""}.`
