+  const handleNext = () => {
+    if (step < TOTAL_STEPS) {
+      setStep(step + 1);
+    } else {
+      mutation.mutate(form);
+    }
+  };
+
+  return (
+    <div className="container" style={{ padding: "2rem 1rem", maxWidth: 600 }}>
+      <div style={{ marginBottom: "2rem" }}>
+        <div style={{ display: "flex", gap: 6, marginBottom: 8 }}>
