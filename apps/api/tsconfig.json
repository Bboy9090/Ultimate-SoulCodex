{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "skipLibCheck": true,
    "types": ["node"],
    "paths": {
      "@soulcodex/db": ["../../packages/db"],
      "@soulcodex/core": ["../../packages/core"],
      "@soulcodex/astrology": ["../../packages/astrology"],
      "@soulcodex/ai": ["../../packages/ai"]
    }
  },
  "files": ["server.ts", "routes.canonical.ts", "storage.ts", "todayRender.ts"],
  "exclude": [
    "index.ts",
    "routes.ts",
    "routes.legacy.ts",
    "db.ts",
    "demo-seed.ts",
    "replit_integrations/**"
  ]
