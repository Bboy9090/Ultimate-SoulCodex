# 
# SOUL CODEX - ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your actual values
#
# DEMO MODE NOTE:
#   Omitting DATABASE_URL runs the app in lightweight demo mode (MemStorage).
#   All data is stored in memory and will be lost on server restart.
#   To persist data, provide a PostgreSQL DATABASE_URL.
# 

# Server Configuration
NODE_ENV=development
PORT=5000

# App
APP_NAME=Soul Codex
# VITE_APP_NAME=Soul Codex   # if needed for client build
# VITE_API_URL=https://api.your-production-domain.com  # absolute API base for native/local webview builds
# CAPACITOR_SERVER_URL=https://your-production-domain.com  # optional: serve app from remote URL in iOS shell

# Session (REQUIRED — the server will refuse to start without this)
# Generate a strong random value, e.g.: openssl rand -hex 32
SESSION_SECRET=your_strong_random_secret_here

# Database (PostgreSQL — recommended for persistent storage; omit to run in MemStorage / demo mode)
# DATABASE_URL=postgresql://user:password@host:port/database

# Google Gemini AI (Required for AI features)
# Obtain a key from https://aistudio.google.com/
GOOGLE_API_KEY=your_google_api_key_here

# Apple Sign-In (required if Sign in with Apple is enabled)
# Must match your Services ID / Bundle configuration used for token verification
# APPLE_CLIENT_ID=app.soulcodex.ios

# 
# Push Notifications (VAPID Keys)
# Generate with: web-push generate-vapid-keys
# 
# VAPID_PUBLIC_KEY=your_public_key_here
# VAPID_PRIVATE_KEY=your_private_key_here
# VAPID_SUBJECT=mailto:support@soulcodex.app

# 
# Stripe (Payment Processing — optional)
# Get your keys from: https://dashboard.stripe.com/apikeys
# 
# STRIPE_SECRET_KEY=sk_test_your_secret_key_here
# STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Stripe Price IDs (create products/prices in Stripe dashboard)
# STRIPE_PRICE_WEEKLY=price_weekly_here
# STRIPE_PRICE_MONTHLY=price_monthly_here
# STRIPE_PRICE_YEARLY=price_yearly_here

# 
# Admin Access (optional)
# 
# ADMIN_PASSWORD=your_secure_admin_password_here
