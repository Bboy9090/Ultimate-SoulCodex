# 
# SOUL CODEX - ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your actual values
# 

# Server Configuration
NODE_ENV=development
PORT=3000

# App
APP_NAME=Soul Codex

# ------------------------------------------------------------------
# Demo Mode
# Set DEMO_MODE=true to run with a seeded demo profile.
# No database required. Useful for local exploration and demos.
# In demo mode, user data is not persisted between server restarts.
# ------------------------------------------------------------------
# DEMO_MODE=true

# ------------------------------------------------------------------
# Database (PostgreSQL - Neon serverless recommended for production)
# If not set and DEMO_MODE is not true, the app uses in-memory
# MemStorage (data lost on restart, suitable for development only).
# ------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@host:port/database

# ------------------------------------------------------------------
# Session
# Required in production. Use a long random string (32+ chars).
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ------------------------------------------------------------------
SESSION_SECRET=change-me-in-production

# ------------------------------------------------------------------
# AI Keys (at least one recommended for AI synthesis features)
# ------------------------------------------------------------------

# Google Gemini (primary AI engine for Codex Reading, Daily synthesis, Soul Guide)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI (fallback AI engine)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4.1-mini

# Astrology API (optional — used by src/astro/provider.ts when switching from local engine)
# ASTRO_API_KEY=your_astro_api_key_here

# ------------------------------------------------------------------
# Push Notifications (VAPID Keys)
# Generate with: npx web-push generate-vapid-keys
# ------------------------------------------------------------------
VAPID_PUBLIC_KEY=your_public_key_here
VAPID_PRIVATE_KEY=your_private_key_here
VAPID_SUBJECT=mailto:support@soulcodex.app

# ------------------------------------------------------------------
# Stripe (Payment Processing)
# Get your keys from: https://dashboard.stripe.com/apikeys
# ------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Stripe Price IDs (create products/prices in Stripe dashboard)
STRIPE_PRICE_WEEKLY=price_weekly_here
STRIPE_PRICE_MONTHLY=price_monthly_here
STRIPE_PRICE_YEARLY=price_yearly_here

# ------------------------------------------------------------------
# Admin Access
# ------------------------------------------------------------------
ADMIN_PASSWORD=your_secure_admin_password_here

# ------------------------------------------------------------------
# Next.js Frontend (upgraded UI — optional)
# When deploying the Next.js frontend from src/ separately (e.g., on
# Vercel), set this to the URL of your Express API server so the
# frontend can make API calls.
# Leave blank when serving both from the same Express server.
# ------------------------------------------------------------------
# NEXT_PUBLIC_API_URL=https://api.soulcodex.app
