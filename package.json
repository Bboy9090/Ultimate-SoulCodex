{
  "name": "ultimate-soulcodex",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Enterprise monorepo for SoulCodex: Engine of the Eternal Now",
  "repository": {
    "type": "git",
    "url": "https://github.com/Bboy9090/Ultimate-SoulCodex.git"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "tsx server/index.ts",
    "build": "npm run build:server && npm run build:client",
    "build:client": "vite build",
    "build:server": "esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outfile=dist/index.js --external:@soulcodex/core --external:@soulcodex/db",
    "build:vercel": "npm run build -w @soulcodex/db && npm run build -w @soulcodex/core && npm run build -w @soulcodex/web",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:init": "drizzle-kit push --config=drizzle.config.ts --force",
    "db:studio": "drizzle-kit studio",
    "check": "npm run check --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present"
  },
  "dependencies": {
    "@soulcodex/core": "*",
    "@soulcodex/db": "*",
