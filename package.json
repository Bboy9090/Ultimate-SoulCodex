{
  "name": "ultimate-soulcodex",
  "private": true,
  "version": "1.0.0",
  "description": "Enterprise monorepo for SoulCodex: Engine of the Eternal Now",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npx tsx server/index.ts",
    "build": "npm run build --workspace=packages/db --if-present && npm run build --workspace=packages/core --if-present && npx esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist --outExtension:.js=.js",
    "start": "node dist/index.js",
    "check": "npm run check --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present"
  },
  "devDependencies": {
    "esbuild": "^0.27.4",
    "eslint": "^8.0.0",
    "prettier": "^3.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@google/genai": "^1.48.0",
    "argon2": "^0.44.0",
    "express-session": "^1.19.0",
    "geo-tz": "^8.1.6",
    "lightningcss": "^1.32.0",
    "memoizee": "^0.4.17",
    "memorystore": "^1.6.7",
    "passport": "^0.7.0",
    "passport-local": "^1.0.0",
    "pdfkit": "^0.18.0",
    "sharp": "^0.34.5",
    "stripe": "^22.0.0",
    "web-push": "^3.6.7",
    "zod-validation-error": "^5.0.0"
  }
}
