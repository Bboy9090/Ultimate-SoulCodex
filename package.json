{
  "name": "ultimate-soulcodex",
  "private": true,
  "version": "1.0.0",
  "description": "Enterprise monorepo for SoulCodex: Engine of the Eternal Now",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {

    "dev": "npm run dev --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "check": "npm run check --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present"
  },
  "devDependencies": {
    "esbuild": "^0.27.4",
    "eslint": "^8.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0"
  }
}

